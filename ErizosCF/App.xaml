<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:ErizosCF.Services"
             x:Class="ErizosCF.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:PercentageToProgressConverter x:Key="PercentageToProgress"/>

            <conv:BoolToTextConverter x:Key="BoolToTextConverter"/>
            <conv:BoolToColorConverter x:Key="BoolToColorConverter"/>

            <Color x:Key="PrimaryTextColorLight">#222222</Color>
            <Color x:Key="PrimaryTextColorDark">#EEEEEE</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
