<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ErizosCF.Views"
    x:Class="ErizosCF.AppShell">

    <FlyoutItem Title="Dashboard">
        <ShellContent ContentTemplate="{DataTemplate views:DashBoardPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Usuarios">
        <ShellContent ContentTemplate="{DataTemplate views:UserManagementPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Comparar Usuarios">
        <ShellContent ContentTemplate="{DataTemplate views:ComparePage}" />
    </FlyoutItem>

    <FlyoutItem Title="Comparar Equipos">
        <ShellContent ContentTemplate="{DataTemplate views:CompareTeamPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Historial de Hitos">
        <ShellContent ContentTemplate="{DataTemplate views:HitosPage}" />
    </FlyoutItem>
</Shell>
